<mvc:View controllerName="com.applexus.mainproject.controller.Registration"
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page2" title="{i18n>title}">
        <customHeader>
            <Bar>
                <contentLeft>
                    <Title text="TURFLEY"
                           titleStyle="H3" />
                </contentLeft>
            </Bar>
        </customHeader>
        <FlexBox width="100%"
                 height="100%"
                 alignItems="Center"
                 justifyContent="Center">
            <Panel width="400px"
                   class="sapUiResponsiveMargin"
                   backgroundDesign="Translucent">
                <content>
                    <VBox alignItems="Center"
                          justifyContent="Center"
                          class="sapUiSmallMargin">
                        <Image src="../Images/image.png"
                               width="150px"
                               class="sapUiSmallMarginBottom"/>
                        <Title text="Register"
                               titleStyle="H3"
                               class="sapUiSmallMarginBottom"/>
                        <Text text="Create an account for Quick Turf Booking"
                              class="sapUiSmallMarginBottom"/>
                        <VBox width="100%">
                            <Label text="Enter your Full Name"/>
                            <Input id="i3"
                                   placeholder="Enter name"
                                   class="sapUiSmallMarginBottom"/>
                            <Label text="Enter your Email"/>
                            <Input id="i4"
                                   placeholder="Enter email"
                                   class="sapUiSmallMarginBottom"/>
                            <Label text="Enter your Password"/>
                            <Input id="i5"
                                   type="Password"
                                   placeholder="Enter password"
                                   class="sapUiSmallMarginBottom"/>
                            <Label text="Confirm your Password"/>
                            <Input id="i6"
                                   type="Password"
                                   placeholder="Enter password again"
                                   class="sapUiSmallMarginBottom"/>
                            <Label text="Enter your Phone Number"/>
                            <Input id="i7"
                                   placeholder="Enter a 10-digit phone number"
                                   class="sapUiSmallMarginBottom"/>
                            <Label text="Choose Role"/>
                            <Select id="i8"
                                    class="sapUiSmallMarginBottom"
                                    width="100%">
                                <items>
                                    <core:Item key="U" text="User"/>
                                    <core:Item key="O" text="Owner"/>
                                </items>
                            </Select>
                            <Button text="Register"
                                    press="onRegister"
                                    type="Emphasized"
                                    width="100%"/>
                        </VBox>
                    </VBox>
                </content>
            </Panel>
        </FlexBox>
    </Page>
</mvc:View>