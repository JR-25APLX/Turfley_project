<mvc:View controllerName="com.applexus.mainproject.controller.UserHome"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page backgroundDesign="List">
        <customHeader>
            <Toolbar height="60px">
                <Title text="TURFLEY" level="H1" titleStyle="H2" />
                <ToolbarSpacer />
                <Image
                    src="../Images/justlogo.png"
                    width="70px"
                    height="70px"
                    decorative="true" />
            </Toolbar>
        </customHeader>
        <content>
            <VBox class="sapUiMediumMargin">
                <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom">
                    <Title text="LIST OF TURFS" level="H2" />
                    <Button
                        text="My Bookings"
                        type="Emphasized"
                        icon="sap-icon://menu2"
                        press="onMyBookings" />
                </HBox>
                <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                    <SearchField
                        id="searchField"
                        placeholder="Search"
                        width="1000px"
                        liveChange="onSearch"
                        class="sapUiSmallMarginEnd" />
                    <MenuButton
                        text="Filter"
                        icon="sap-icon://filter"
                        buttonMode="Regular">
                        <menu>
                            <Menu itemSelected="onFilterSelect">
                                <items>
                                    <MenuItem key="location" text="Location" />
                                    <MenuItem key="turfType" text="Turf Type" />
                                </items>
                            </Menu>
                        </menu>
                    </MenuButton>
                </HBox>
            </VBox>
        </content>
    </Page>
</mvc:View>