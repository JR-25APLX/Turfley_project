<mvc:View controllerName="com.applexus.mainproject.controller.Payment"
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <Page enableScrolling="true" backgroundDesign="List">

        <customHeader>
            <Toolbar height="60px">
                <Title text="TURFLEY" level="H1" titleStyle="H2"/>
                <ToolbarSpacer/>
                <Image
                    src="../Images/justlogo.png"
                    width="50px"
                    height="70px"
                    decorative="true"/>
            </Toolbar>
        </customHeader>

        <content>
            <FlexBox
                width="100%"
                height="100%"
                alignItems="Center"
                justifyContent="Center">

                <Panel
                    width="450px"
                    backgroundDesign="Solid"
                    class="sapUiResponsiveMargin">

                    <content>
                        <VBox
                            alignItems="Center"
                            justifyContent="Center"
                            class="sapUiMediumMargin">

                            <!-- Title -->
                            <Title
                                text="PAYMENT METHOD"
                                titleStyle="H3"
                                class="sapUiSmallMarginBottom"/>

                            <!-- QR Code Placeholder -->
                            <Image
                                src="../Images/qr.png"
                                width="200px"
                                height="200px"
                                class="sapUiSmallMarginBottom"/>

                            <Text
                                text="Scan the QR Code to Pay"
                                class="sapUiSmallMarginBottom"/>

                            <!-- Separator -->
                            <core:HTML content="&lt;hr style='width:100%'/&gt;" class="sapUiSmallMarginBottom"/>

                            <!-- UPI ID Row with Info Button -->
                            <HBox
                                alignItems="Center"
                                width="100%"
                                class="sapUiSmallMarginBottom">

                                <Input
                                    id          = "upiInput"
                                    placeholder = "Enter your UPI ID"
                                    width       = "100%"
                                    liveChange  = "onUpiChange"/>

                                <Button
                                    icon  = "sap-icon://information"
                                    type  = "Transparent"
                                    press = "onUpiInfo"/>

                            </HBox>

                            <!-- Confirm Payment Button -->
                            <Button
                                text    = "Confirm Payment"
                                type    = "Emphasized"
                                width   = "100%"
                                enabled = "{/payment/isButtonEnabled}"
                                press   = "onConfirmPayment"
                                class   = "sapUiSmallMarginBottom"/>

                            <!-- Success Message — visible only after payment -->
                            <VBox
                                visible     = "{/payment/isPaymentDone}"
                                alignItems  = "Center"
                                class       = "sapUiMediumMarginTop">

                                <Image
                                src="../Images/Paytick.png"
                                width="90px"
                                height="85px"
                                class="sapUiSmallMarginBottom"/>
                                <Title
                                    text       = "Payment Successful"
                                    titleStyle = "H3"
                                    class      = "sapUiSmallMarginBottom"/>

                                <Text text="Your Slot has been Booked!"/>

                            </VBox>

                        </VBox>
                    </content>
                </Panel>
            </FlexBox>
        </content>
    </Page>
</mvc:View>