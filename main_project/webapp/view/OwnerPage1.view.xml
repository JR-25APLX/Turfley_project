<mvc:View xmlns:core="sap.ui.core" controllerName="com.applexus.mainproject.controller.OwnerPage1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:g="sap.ui.layout">
    <Page id="page4" title="{i18n>title}">
    <customHeader>
            <Toolbar height="60px">
                <Title text="TURFLEY" level="H1" titleStyle="H2" />    
 
            <!-- This will push Logo to the Right Side -->
                <ToolbarSpacer />
 
            <!-- Logo of Turfley  -->
                <Image
                src="../Images/justlogo.png"
                width="70px"
                height="70px"
                decorative="true" />
            </Toolbar>
    </customHeader>

    <content>
        <VBox class="sapUiMediumMargin" >

            <Title text="OWNER" level="H1" titleStyle="H3"/> 

            <IconTabBar class="sapUiSmallMarginTop" select="onTabSelect" >
                <items>
                    <IconTabFilter text="Edit your Turf Here" key="Edit" />
                    <IconTabFilter text="Add your Turf Here" key="Add" />                 
                </items>           
            </IconTabBar>

            <VBox id="edit" visible="true">
            <g:Grid defaultSpan="L4 M6 S12" class="sapUiSmallMarginTop">

                <VBox>
                    <Label text="Turf Name"/>
                    <Input value=" " id="i8"/>
                </VBox>

                <VBox>
                    <Label text="Turf Location"/>
                    <Input value=" " id="i9" />
                </VBox>

                <VBox>
                    <Label text="Base Price"/>
                    <Input value="" id="i10"/>
                </VBox>

            </g:Grid>

            <g:Grid defaultSpan="L4 M6 S12" class="sapUiSmallMarginTop">

                <VBox>
                    <Label text="Turf ID"/>
                    <Input value=" " id="i11"/>
                </VBox>

                <VBox>
                    <Label text="Turf Location URL"/>
                    <Input value=" " id="i12"/>
                </VBox>

            </g:Grid>

            <g:Grid defaultSpan="L4 M6 S12" class="sapUiSmallMarginTop">

                <VBox>
                    <Label text="Owner ID"/>
                    <Input value=" " id="i13"/>
                </VBox>

                <VBox>
                    <Label text="Turf Type"/>
                    <Input value=" " id="i14"/>
                </VBox>

            </g:Grid>

            <HBox justifyContent="Center" class="sapUiSmallMarginTop">
                <Button text="Save Changes" type="Emphasized" press="onSaveChanges"/>
            </HBox>
            </VBox>

            <VBox id="add" visible="false">
            <g:Grid defaultSpan="L4 M6 S12" class="sapUiSmallMarginTop">

                <VBox>
                    <Label text="Enter Turf ID"/>
                    <Input value=" " id="i15"/>
                </VBox>

                <VBox>
                    <Label text="Enter Turf Location"/>
                    <Input value=" " id="i16" />
                </VBox>

                <VBox>
                    <Label text="Enter Turf Type"/>
                    <Input value="" id="i17"/>
                </VBox>

            </g:Grid>

            <g:Grid defaultSpan="L4 M6 S12" class="sapUiSmallMarginTop">

                <VBox>
                    <Label text="Enter Turf Name"/>
                    <Input value=" " id="i18"/>
                </VBox>

                <VBox>
                    <Label text="Enter Turf Location URL"/>
                    <Input value=" " id="i19" />
                </VBox>

                <VBox>
                    <Label text="Enter Currency Key"/>
                    <Input value=" " id="i20" />
                </VBox>
            </g:Grid>

            <g:Grid defaultSpan="L4 M6 S12" class="sapUiSmallMarginTop">

                <VBox>
                    <Label text="Enter Turf Price"/>
                    <Input value=" " id="i21"/>
                </VBox>

                <VBox>
                    <Label text="Enter your Owner Id"/>
                    <Input value=" " id="i22" />
                </VBox>

            </g:Grid>

            <HBox justifyContent="Center" class="sapUiSmallMarginTop">
                <Button text="Add + " type="Emphasized" press="onAdd"/>
            </HBox>

            </VBox>       
        </VBox>      
    </content>      
    </Page>
</mvc:View>
 



